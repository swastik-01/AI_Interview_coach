# AI Interview Coach — Environment Variables

# Supabase (required for auth — get from Supabase Dashboard > Settings > API)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# AI API Keys (required — calls are made directly from the browser)
VITE_NVIDIA_API_KEY="nvapi-..."
VITE_SARVAM_API_KEY="your-sarvam-key"
